{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/sync/notion",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/sync/skill-submissions",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/sync/skills",
      "schedule": "0 10 * * 1"
    }
  ]
}
