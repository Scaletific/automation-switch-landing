# ─────────────────────────────────────────────────────────────────────────────
# Automation Switch — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Add all variables to Vercel → Project Settings → Environment Variables too.
# ─────────────────────────────────────────────────────────────────────────────

# ── SANITY ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=l4o4vshf
NEXT_PUBLIC_SANITY_DATASET=production

# Read-only token — used by the frontend to fetch published content
# Get from: https://sanity.io/manage → project → API → Tokens → Add API token (Viewer)
SANITY_API_TOKEN=your_sanity_read_token

# Write/Editor token — used ONLY by the sync script (server-side, never exposed to client)
# Get from: https://sanity.io/manage → project → API → Tokens → Add API token (Editor)
SANITY_WRITE_TOKEN=your_sanity_write_token

# ── NOTION ───────────────────────────────────────────────────────────────────
# Integration token — create at: https://www.notion.so/my-integrations
# Share your Articles database with the integration after creating it.
NOTION_API_TOKEN=secret_your_notion_integration_token

# Articles database ID — the part of the URL after notion.so/ (no dashes)
NOTION_ARTICLES_DB_ID=1c0a0caa82bd4e9c96f85b55f93440aa

# Skill Submissions database ID — create a Notion DB called "Skill Submissions"
# under the Automation Switch parent page, share it with your integration, paste ID here
NOTION_SUBMISSIONS_DB_ID=your_submissions_db_id_here

# ── SYNC SECURITY ────────────────────────────────────────────────────────────
# Secret for manually triggering the sync (POST /api/sync/notion with x-sync-secret header)
# Generate with: openssl rand -hex 32
SYNC_SECRET=your_random_sync_secret_here

# Vercel automatically injects CRON_SECRET for cron jobs — you do NOT set this manually.
# It's listed here for documentation only.
# CRON_SECRET=(managed by Vercel)

# ── BEEHIIV ──────────────────────────────────────────────────────────────────
# Newsletter subscription API
# Get from: https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_beehiiv_publication_id
